---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "../styles/style.scss";
const { title } = Astro.props;
import { SEO } from "astro-seo";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description="Nexterは、Udemy講座のサンプルサイトです。"
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: "/assets/images/SEO.webp",
        },
      }}
      twitter={{
        creator: "@gdk0918",
      }},
      extend={{
        link: [{ rel: "icon", href: "/favicon.ico" }],
        meta: [
          {
            name: "twitter:image",
            content: "/assets/images/SEO.webp",
          },
          { name: "twitter:title", content: "Nexter" },
          { name: "twitter:description", content: "Nexterは、Udemy講座のサンプルサイトです。" },
        ],
      }}
    />
    <link href="https://fonts.googleapis.com/css?family=Josefin+Sans:300,400,400i|Nunito:300,300i" rel="stylesheet">
    <link rel="shortcut icon" type="image/png" href="/assets/images/favicon.png">
  </head>
  <body class="l-container">
    <slot />
    <script type="module" src="/assets/js/index.js"></script>
  </body>
</html>
