  <section class="p-gallery">
    <figure class="p-gallery__item p-gallery__item--1">
      <img src={`${import.meta.env.BASE_URL}assets/images/gal-1.jpeg`} alt="" class="p-gallery__img">
    </figure>
    <figure class="p-gallery__item p-gallery__item--1"><img src={`${import.meta.env.BASE_URL}assets/images/gal-1.jpeg`} alt="Gallery image 1" class="p-gallery__img"></figure>
    <figure class="p-gallery__item p-gallery__item--2"><img src={`${import.meta.env.BASE_URL}assets/images/gal-2.jpeg`} alt="Gallery image 2" class="p-gallery__img"></figure>
