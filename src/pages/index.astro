        <svg class="p-homes__icon p-homes__icon--heart">
          <use xlink:href={`${import.meta.env.BASE_URL}assets/images/sprite.svg#icon-heart-full`}></use>
        </svg>
      <h5 class="p-homes__name">Majestic Palace House</h5>
      <div class="p-homes__location">
