          <use xlink:href={`${import.meta.env.BASE_URL}assets/images/sprite.svg#icon-heart-full`}></use>
        </svg>
      <h5 class="p-homes__name">Beautiful Family House</h5>
      <div class="p-homes__location">
        <svg class="p-homes__icon">
          <use xlink:href={`${import.meta.env.BASE_URL}assets/images/sprite.svg#icon-map-pin`}></use>
        </svg>
        <p>USA</p>
      </div>
      <div class="p-homes__rooms">
        <svg class="p-homes__icon">
          <use xlink:href={`${import.meta.env.BASE_URL}assets/images/sprite.svg#icon-profile-male`}></use>
        </svg>
        <p>5 rooms</p>
      </div>
      <div class="p-homes__area">
        <svg class="p-homes__icon">
          <use xlink:href={`${import.meta.env.BASE_URL}assets/images/sprite.svg#icon-expand`}></use>
        </svg>
        <p>325m<sup>2</sup></p>
      </div>
      <div class="p-homes__price">
        <svg class="p-homes__icon">
          <use xlink:href={`${import.meta.env.BASE_URL}assets/images/sprite.svg#icon-key`}></use>
        </svg>
        <p>$1,200,000</p>
      </div>
      <button class="c-button p-homes__button">Contact realtor</button>
